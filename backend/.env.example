# Application
NODE_ENV=development
PORT=5000
APP_NAME="Project Management API"

# Database
MONGODB_URI=mongodb://localhost:27017/mgt_app
# Or use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/mgt_app?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here_change_this_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880
